# AcademyKit WhatsApp Bot - Environment Variables
# Copy this file to .env and fill in the values

# Twilio credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Supabase credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AcademyKit URL (the main web app URL)
ACADEMYKIT_URL=http://localhost:3000

# Lesson link signing secret
WHATSAPP_LINK_SECRET=your_strong_secret_key_here

# Port for the bot server
PORT=3003
